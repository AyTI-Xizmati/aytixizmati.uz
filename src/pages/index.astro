---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Process from '../components/Process.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import PixelSnow from '../components/PixelSnow.astro';
import ClickSpark from '../components/ClickSpark.astro';
import data from '../i18n/uz.json';

const lang = 'uz';
---

<Layout
  lang={lang}
  title={data.seo.title}
  description={data.seo.description}
  keywords={data.seo.keywords}
  faqItems={data.faq.items}
  serviceItems={data.services.items}
>
  <PixelSnow
    style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1;"
  />
  <ClickSpark />
  <Navbar lang={lang} nav={data.nav} />
  <Hero hero={data.hero} />
  <Services services={data.services} />
  <Process process={data.process} />
  <FAQ faq={data.faq} />
  <Contact contact={data.contact} />
  <Footer footer={data.footer} />
</Layout>
