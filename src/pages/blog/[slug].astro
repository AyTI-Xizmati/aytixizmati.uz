---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import uz from '../../i18n/uz.json';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const lang = post.data.lang || 'uz';
const baseUrl = 'https://aytixizmati.uz';
const postUrl = `${baseUrl}/blog/${post.slug}`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  '@id': `${postUrl}#article`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date,
  dateModified: post.data.date,
  inLanguage: lang,
  keywords: post.data.tags.join(', '),
  author: {
    '@type': 'Organization',
    name: post.data.author,
    url: baseUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'AyTi Xizmati',
    url: baseUrl,
    logo: { '@type': 'ImageObject', url: `${baseUrl}/favicon.svg` },
  },
  image: `${baseUrl}/og-image.png`,
};

const breadcrumbs = [
  { name: 'Asosiy', url: baseUrl },
  { name: 'Blog', url: `${baseUrl}/blog` },
  { name: post.data.title, url: postUrl },
];

const isPlaceholder = post.slug === 'placeholder';
---

<Layout
  lang={lang}
  title={`${post.data.title} — AyTi Xizmati Blog`}
  description={post.data.description}
  keywords={post.data.tags.join(', ')}
  ogType="article"
  breadcrumbs={breadcrumbs}
  faqItems={post.data.faqItems}
  noindex={isPlaceholder}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <Navbar lang={lang} nav={uz.nav} />

  <article class="blog-post" itemscope itemtype="https://schema.org/BlogPosting">
    <div class="container">
      <nav class="blog-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Asosiy</a> &rsaquo; <a href="/blog">Blog</a> &rsaquo;
        <span aria-current="page">{post.data.title}</span>
      </nav>
      <div class="blog-post-meta">
        <time class="blog-post-date" datetime={post.data.date} itemprop="datePublished">{post.data.date}</time>
        <div class="blog-post-tags">
          {post.data.tags.map((tag) => (
            <span class="blog-tag">{tag}</span>
          ))}
        </div>
      </div>
      <h1 class="blog-post-title" itemprop="headline">{post.data.title}</h1>
      <div class="blog-post-content" itemprop="articleBody">
        <Content />
      </div>
    </div>
  </article>

  <Footer footer={uz.footer} />
</Layout>
