---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import en from '../../../i18n/en.json';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'en');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const lang = 'en';
const baseUrl = 'https://aytixizmati.uz';
const postUrl = `${baseUrl}/en/blog/${post.slug}`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  '@id': `${postUrl}#article`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date,
  dateModified: post.data.date,
  inLanguage: lang,
  keywords: post.data.tags.join(', '),
  author: { '@type': 'Organization', name: post.data.author, url: baseUrl },
  publisher: {
    '@type': 'Organization',
    name: 'AyTi Xizmati',
    url: baseUrl,
    logo: { '@type': 'ImageObject', url: `${baseUrl}/favicon.svg` },
  },
  image: `${baseUrl}/og-image.png`,
};

const breadcrumbs = [
  { name: 'Home', url: `${baseUrl}/en` },
  { name: 'Blog', url: `${baseUrl}/en/blog` },
  { name: post.data.title, url: postUrl },
];
---

<Layout
  lang={lang}
  title={`${post.data.title} — AyTi Xizmati Blog`}
  description={post.data.description}
  keywords={post.data.tags.join(', ')}
  ogType="article"
  breadcrumbs={breadcrumbs}
  faqItems={post.data.faqItems}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <Navbar lang={lang} nav={en.nav} />

  <article class="blog-post" itemscope itemtype="https://schema.org/BlogPosting">
    <div class="container">
      <nav class="blog-breadcrumb" aria-label="Breadcrumb">
        <a href="/en">Home</a> &rsaquo; <a href="/en/blog">Blog</a> &rsaquo;
        <span aria-current="page">{post.data.title}</span>
      </nav>
      <div class="blog-post-meta">
        <time class="blog-post-date" datetime={post.data.date} itemprop="datePublished">{post.data.date}</time>
        <div class="blog-post-tags">
          {post.data.tags.map((tag) => (
            <span class="blog-tag">{tag}</span>
          ))}
        </div>
      </div>
      <h1 class="blog-post-title" itemprop="headline">{post.data.title}</h1>
      <div class="blog-post-content" itemprop="articleBody">
        <Content />
      </div>
    </div>
  </article>

  <Footer footer={en.footer} />
</Layout>
