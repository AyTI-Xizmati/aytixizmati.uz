---
interface ServiceItem {
  icon: string;
  title: string;
  price: string;
  description: string;
  features: string[];
}

interface Props {
  services: {
    title: string;
    subtitle: string;
    cta: string;
    items: ServiceItem[];
  };
}

const { services } = Astro.props;

const iconPaths: Record<string, string> = {
  website: '<path d="M3 3h18a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  crm: '<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/><path d="M7 8h2v4H7z"/><path d="M11 7h2v5h-2z"/><path d="M15 9h2v3h-2z"/>',
  mobile: '<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>',
  telegram: '<path d="M22 2L11 13"/><path d="M22 2L15 22L11 13L2 9L22 2Z"/>',
  support: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M12 7v2"/><path d="M12 13h.01"/>',
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/>',
};
---

<section class="services" id="xizmatlar">
  <div class="container">
    <h2 class="section-title">{services.title}</h2>
    <p class="services-subtitle">{services.subtitle}</p>
    <div class="services-grid">
      {services.items.map(item => (
        <div class="service-card">
          <div class="service-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28">
              <Fragment set:html={iconPaths[item.icon] || iconPaths.code} />
            </svg>
          </div>
          <div class="service-header">
            <h3 class="service-title">{item.title}</h3>
            <span class="service-price">{item.price}</span>
          </div>
          <p class="service-description">{item.description}</p>
          <ul class="service-features">
            {item.features.map(f => (
              <li>{f}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="services-cta-container">
      <a href="#aloqa" class="btn btn-pricing-main">{services.cta}</a>
    </div>
  </div>
</section>
