---
interface Props {
  title: string;
  description: string;
  date: string;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;
---

<a href={`/blog/${slug}`} class="blog-card">
  <div class="blog-card-date">{date}</div>
  <h3 class="blog-card-title">{title}</h3>
  <p class="blog-card-desc">{description}</p>
  <div class="blog-card-tags">
    {tags.map(tag => (
      <span class="blog-tag">{tag}</span>
    ))}
  </div>
  <span class="blog-card-read">O'qish &rarr;</span>
</a>
