---
interface Props {
  pricing: {
    title: string;
    cta: string;
    plans: {
      name: string;
      price: string;
      features: string[];
    }[];
  };
}

const { pricing } = Astro.props;
---

<section class="pricing" id="narxlar">
  <div class="container">
    <h2 class="section-title">{pricing.title}</h2>
    <div class="pricing-grid">
      {pricing.plans.map(plan => (
        <div class="pricing-card">
          <h3>{plan.name}</h3>
          <ul class="pricing-features">
            {plan.features.map(feature => (
              <li>{feature}</li>
            ))}
          </ul>
          <div class="price-tag">{plan.price}</div>
        </div>
      ))}
    </div>
    <div class="pricing-cta-container">
      <a href="#aloqa" class="btn btn-pricing-main">{pricing.cta}</a>
    </div>
  </div>
</section>
