---
interface Props {
  hero: {
    title: string;
    titleAccent?: string;
    subtitle: string;
    cta1: string;
    cta2: string;
    stats: { number: string; label: string }[];
  };
}

const { hero } = Astro.props;
---

<section class="hero" id="asosiy">
  <slot name="background" />
  <div class="hero-num">IT</div>
  <div class="hero-border"></div>
  <div class="hero-c">
    <div class="hero-ey">AyTi Xizmati</div>
    <h1 class="hero-title">
      {hero.title}
      {hero.titleAccent && <span class="hero-title-accent">{hero.titleAccent}</span>}
    </h1>
    <p class="hero-subtitle">{hero.subtitle}</p>
    <div class="hero-btns">
      <a href="#aloqa" class="hero-bp">{hero.cta1}</a>
      <a href="#xizmatlar" class="hero-bs">{hero.cta2}</a>
    </div>
  </div>
</section>
