---
interface Props {
  contact: {
    title: string;
    form: {
      name: string;
      phone: string;
      username: string;
      message: string;
      messagePlaceholder: string;
      submit: string;
      submitting: string;
    };
    success: string;
    error: string;
  };
}

const { contact } = Astro.props;
const scriptUrl =
  'https://script.google.com/macros/s/AKfycbzY4dcLVdK9fgpazoCmgbX8ZHmdEaWwd17E-mOTbwBUSFSMmU9O9e9dy5MIUeee2RkVFw/exec';
---

<div
  id="contact-toast"
  class="toast-notification"
  role="status"
  aria-live="polite"
  hidden
></div>

<section class="contact" id="aloqa" aria-labelledby="contact-title">
  <div class="container">
    <h2 class="section-title" id="contact-title">{contact.title}</h2>
    <div class="contact-form-container">
      <form
        class="contact-form"
        id="contact-form"
        data-endpoint={scriptUrl}
        data-success={contact.success}
        data-error={contact.error}
        data-submit={contact.form.submit}
        data-submitting={contact.form.submitting}
        novalidate
      >
        <div class="form-group">
          <label for="contact-name">{contact.form.name}</label>
          <input
            type="text"
            id="contact-name"
            name="name"
            required
            autocomplete="name"
            minlength="2"
          />
        </div>
        <div class="form-group">
          <label for="contact-phone">{contact.form.phone}</label>
          <input
            type="tel"
            id="contact-phone"
            name="phone"
            required
            autocomplete="tel"
            placeholder="+998 XX XXX XX XX"
            inputmode="tel"
            pattern="\+998\s?\d{2}\s?\d{3}\s?\d{2}\s?\d{2}"
          />
        </div>
        <div class="form-group">
          <label for="contact-username">{contact.form.username}</label>
          <input
            type="text"
            id="contact-username"
            name="username"
            placeholder="@username"
            autocomplete="off"
          />
        </div>
        <div class="form-group">
          <label for="contact-message">{contact.form.message}</label>
          <textarea
            id="contact-message"
            name="message"
            rows="3"
            required
            placeholder={contact.form.messagePlaceholder}></textarea>
        </div>
        <button type="submit" class="submit-btn" id="contact-submit">
          {contact.form.submit}
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    const toast = document.getElementById('contact-toast') as HTMLElement;
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;
    const nameInput = form.elements.namedItem('name') as HTMLInputElement;
    const phoneInput = form.elements.namedItem('phone') as HTMLInputElement;
    const usernameInput = form.elements.namedItem('username') as HTMLInputElement;

    const cfg = {
      endpoint: form.dataset.endpoint!,
      success: form.dataset.success!,
      error: form.dataset.error!,
      submit: form.dataset.submit!,
      submitting: form.dataset.submitting!,
    };

    let toastTimer: number | undefined;
    const showToast = (msg: string, type: 'success' | 'error') => {
      toast.textContent = msg;
      toast.className = `toast-notification toast-${type}`;
      toast.hidden = false;
      window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => {
        toast.hidden = true;
      }, type === 'success' ? 4000 : 3000);
    };

    nameInput.addEventListener('input', () => {
      const v = nameInput.value;
      if (v.length > 0) nameInput.value = v.charAt(0).toUpperCase() + v.slice(1);
    });

    phoneInput.addEventListener('focus', () => {
      if (!phoneInput.value) phoneInput.value = '+998 ';
    });
    phoneInput.addEventListener('input', () => {
      const digits = phoneInput.value.replace(/\D/g, '');
      let cleaned = digits.startsWith('998') ? digits.slice(3) : digits;
      cleaned = cleaned.slice(0, 9);
      let formatted = '+998 ';
      if (cleaned.length === 0) formatted = '+998 ';
      else if (cleaned.length <= 2) formatted = `+998 ${cleaned}`;
      else if (cleaned.length <= 5) formatted = `+998 ${cleaned.slice(0, 2)} ${cleaned.slice(2)}`;
      else if (cleaned.length <= 7)
        formatted = `+998 ${cleaned.slice(0, 2)} ${cleaned.slice(2, 5)} ${cleaned.slice(5)}`;
      else
        formatted = `+998 ${cleaned.slice(0, 2)} ${cleaned.slice(2, 5)} ${cleaned.slice(5, 7)} ${cleaned.slice(7)}`;
      phoneInput.value = formatted;
    });

    usernameInput.addEventListener('input', () => {
      const cleaned = usernameInput.value.replace(/@/g, '');
      usernameInput.value = cleaned ? `@${cleaned}` : '@';
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const name = String(data.get('name') || '').trim();
      const phoneRaw = String(data.get('phone') || '');
      const phoneDigits = phoneRaw.replace(/\D/g, '');
      if (name.length < 2 || phoneDigits.length !== 12) {
        showToast(cfg.error, 'error');
        return;
      }
      submitBtn.disabled = true;
      submitBtn.textContent = cfg.submitting;
      try {
        const body = new URLSearchParams({
          name,
          phone: phoneDigits.slice(3),
          phoneDisplay: phoneRaw.replace(/\s/g, ''),
          username: String(data.get('username') || ''),
          message: String(data.get('message') || ''),
        }).toString();
        const controller = new AbortController();
        const timeoutId = window.setTimeout(() => controller.abort(), 10000);
        await fetch(cfg.endpoint, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body,
          signal: controller.signal,
        });
        window.clearTimeout(timeoutId);
        showToast(cfg.success, 'success');
        form.reset();
      } catch {
        showToast(cfg.error, 'error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = cfg.submit;
      }
    });
  }
</script>
